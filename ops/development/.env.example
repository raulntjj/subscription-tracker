# ============================================
# Subscription Tracker — Development Environment
# ============================================
# APP_KEY: php artisan key:generate --show
# JWT_SECRET: php artisan jwt:secret --show

# --- Backend (Laravel) ---
APP_NAME=subscription-tracker
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en

APP_MAINTENANCE_DRIVER=file

CORS_ALLOWED_ORIGINS=http://localhost:3000

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

OCTANE_SERVER=frankenphp

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Database (MySQL) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=subscription-tracker
DB_USERNAME=root
DB_PASSWORD=root

MYSQL_ROOT_PASSWORD=root

# --- Cache (Redis) ---
CACHE_STORE=redis
CACHE_DRIVER=redis
CACHE_PREFIX=subscription_tracker_cache
REDIS_CLIENT=phpredis
REDIS_PASSWORD=null
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379

# --- Sessions (Redis) ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
REDIS_SESSION_HOST=redis-sessions
REDIS_SESSION_PORT=6379

# --- Queue (RabbitMQ) ---
QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=root
RABBITMQ_PASSWORD=root
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=default
RABBITMQ_EXCHANGE_NAME=laravel
RABBITMQ_EXCHANGE_TYPE=direct
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=root
RABBITMQ_DEFAULT_PASS=root
RABBITMQ_DEFAULT_VHOST=/

# --- Mail ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- JWT ---
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

VITE_APP_NAME="${APP_NAME}"

# --- Frontend (Next.js) ---
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_API_BASE_URL=http://backend:8000
WATCHPACK_POLLING=true

# --- Redis Commander ---
REDIS_HOSTS=cache:redis-cache:6379,sessions:redis-sessions:6379
HTTP_USER=root
HTTP_PASSWORD=root
